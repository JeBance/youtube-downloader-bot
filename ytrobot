#!/bin/bash
# YouTube Downloader Bot Manager
# Использование: ytrobot {start|stop|restart|status|logs|enable|disable}

BOT_NAME="YouTube Downloader Bot"
BOT_USER="ytrobot"
BOT_GROUP="ytrobot"
BOT_DIR="/root/git/youtube-downloader-bot"
BOT_FILE="bot.py"
VENV_DIR="$BOT_DIR/venv"
PID_FILE="/tmp/ytrobot.pid"
LOG_FILE="$BOT_DIR/ytrobot.log"
SYSTEMD_SERVICE="/etc/systemd/system/ytrobot.service"

# Цвета для вывода
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_status() {
    echo -e "${BLUE}▶${NC} $1"
}

print_success() {
    echo -e "${GREEN}✔${NC} $1"
}

print_error() {
    echo -e "${RED}✖${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

check_installed() {
    if [ ! -d "$BOT_DIR" ]; then
        print_error "Директория бота не найдена: $BOT_DIR"
        exit 1
    fi
    
    if [ ! -f "$BOT_DIR/$BOT_FILE" ]; then
        print_error "Файл бота не найден: $BOT_DIR/$BOT_FILE"
        exit 1
    fi
    
    if [ ! -d "$VENV_DIR" ]; then
        print_error "Виртуальное окружение не найдено: $VENV_DIR"
        exit 1
    fi
}

get_pid() {
    if [ -f "$PID_FILE" ]; then
        local pid=$(cat "$PID_FILE")
        if ps -p "$pid" > /dev/null 2>&1; then
            echo "$pid"
            return 0
        fi
    fi
    # Альтернативный поиск
    pgrep -f "python.*$BOT_FILE" | head -1
}

start_bot() {
    local pid=$(get_pid)
    if [ -n "$pid" ]; then
        print_warning "Бот уже запущен (PID: $pid)"
        return 0
    fi
    
    print_status "Запуск бота от имени $BOT_USER..."
    
    # Создаём лог файл с правильными правами
    touch "$LOG_FILE"
    chown "$BOT_USER:$BOT_GROUP" "$LOG_FILE"
    
    # Запускаем от имени пользователя
    su -s /bin/bash "$BOT_USER" -c "cd $BOT_DIR && source $VENV_DIR/bin/activate && nohup python $BOT_FILE > $LOG_FILE 2>&1 &"
    
    sleep 2
    
    local new_pid=$(get_pid)
    if [ -n "$new_pid" ]; then
        echo "$new_pid" > "$PID_FILE"
        print_success "Бот запущен (PID: $new_pid)"
        return 0
    else
        print_error "Не удалось запустить бота. Проверьте лог: $LOG_FILE"
        return 1
    fi
}

stop_bot() {
    local pid=$(get_pid)
    if [ -z "$pid" ]; then
        print_warning "Бот не запущен"
        return 0
    fi
    
    print_status "Остановка бота (PID: $pid)..."
    kill "$pid" 2>/dev/null
    
    # Ждём остановки
    for i in {1..10}; do
        if ! ps -p "$pid" > /dev/null 2>&1; then
            print_success "Бот остановлен"
            rm -f "$PID_FILE"
            return 0
        fi
        sleep 1
    done
    
    # Принудительная остановка
    print_warning "Принудительная остановка..."
    kill -9 "$pid" 2>/dev/null
    rm -f "$PID_FILE"
    print_success "Бот остановлен"
}

restart_bot() {
    print_status "Перезапуск бота..."
    stop_bot
    sleep 1
    start_bot
}

status_bot() {
    local pid=$(get_pid)
    if [ -n "$pid" ] && ps -p "$pid" > /dev/null 2>&1; then
        print_success "Бот работает (PID: $pid)"
        
        # Дополнительная информация
        if [ -f "$LOG_FILE" ]; then
            local log_lines=$(wc -l < "$LOG_FILE")
            echo "  Лог файл: $LOG_FILE ($log_lines строк)"
        fi
        
        # Проверка Bot API Server
        if systemctl is-active --quiet telegram-bot-api 2>/dev/null; then
            echo "  Bot API Server: ${GREEN}работает${NC}"
        else
            echo "  Bot API Server: ${YELLOW}не работает${NC}"
        fi
        
        return 0
    else
        print_error "Бот не работает"
        rm -f "$PID_FILE"
        return 1
    fi
}

logs_bot() {
    if [ -f "$LOG_FILE" ]; then
        tail -50 "$LOG_FILE"
    else
        print_warning "Лог файл не найден"
    fi
}

enable_autostart() {
    print_status "Включение автозапуска..."
    
    # Создаём systemd службу
    cat > "$SYSTEMD_SERVICE" << EOF
[Unit]
Description=YouTube Downloader Telegram Bot
After=network.target telegram-bot-api.service

[Service]
Type=simple
User=$BOT_USER
Group=$BOT_GROUP
WorkingDirectory=$BOT_DIR
Environment=PATH=$VENV_DIR/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=$VENV_DIR/bin/python $BOT_FILE
Restart=on-failure
RestartSec=10
StandardOutput=append:$LOG_FILE
StandardError=append:$LOG_FILE

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=$BOT_DIR/downloads

[Install]
WantedBy=multi-user.target
EOF
    
    systemctl daemon-reload
    systemctl enable ytrobot.service
    
    # Настраиваем права на лог файл
    touch "$LOG_FILE"
    chown "$BOT_USER:$BOT_GROUP" "$LOG_FILE"
    
    print_success "Автозапуск включён"
    print_status "Для запуска выполните: systemctl start ytrobot"
}

disable_autostart() {
    print_status "Отключение автозапуска..."
    
    systemctl disable ytrobot.service 2>/dev/null
    rm -f /etc/systemd/system/ytrobot.service
    systemctl daemon-reload
    
    print_success "Автозапуск отключён"
}

show_help() {
    echo "YouTube Downloader Bot Manager"
    echo ""
    echo "Использование: ytrobot {команда}"
    echo ""
    echo "Команды:"
    echo "  start    - Запустить бота"
    echo "  stop     - Остановить бота"
    echo "  restart  - Перезапустить бота"
    echo "  status   - Показать статус"
    echo "  logs     - Показать последние логи"
    echo "  enable   - Включить автозапуск"
    echo "  disable  - Отключить автозапуск"
    echo ""
    echo "Примеры:"
    echo "  ytrobot start"
    echo "  ytrobot restart"
    echo "  ytrobot enable  # для автозапуска при загрузке сервера"
}

# Основная логика
check_installed

case "$1" in
    start)
        start_bot
        ;;
    stop)
        stop_bot
        ;;
    restart)
        restart_bot
        ;;
    status)
        status_bot
        ;;
    logs)
        logs_bot
        ;;
    enable)
        enable_autostart
        ;;
    disable)
        disable_autostart
        ;;
    *)
        show_help
        exit 1
        ;;
esac
