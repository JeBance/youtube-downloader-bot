[Unit]
Description=YouTube Downloader Telegram Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/git/youtube-downloader-bot
Environment=PATH=/root/git/youtube-downloader-bot/venv/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/root/git/youtube-downloader-bot/venv/bin/python bot.py
Restart=on-failure
RestartSec=10

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/root/git/youtube-downloader-bot/downloads

[Install]
WantedBy=multi-user.target
