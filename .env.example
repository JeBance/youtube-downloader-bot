# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# Telegram User ID (для админских команд)
ADMIN_ID=your_telegram_id

# URL локального Bot API Server (опционально)
# Если указан, бот может отправлять файлы до 2GB
# Пример: http://localhost:8081/bot<token>
BOT_API_SERVER_URL=

# Максимальный размер файла для отправки (в байтах)
# По умолчанию 50MB (лимит публичного API Telegram)
# При использовании локального Bot API Server можно установить до 2GB (2147483648)
MAX_FILE_SIZE=52428800

# Путь для временного хранения загрузок
DOWNLOAD_PATH=/root/git/youtube-downloader-bot/downloads

# Лог-уровень: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# === Настройки очереди загрузок ===

# Лимит запросов к YouTube в секунду (рекомендуется 0.5-1.0 для стабильности)
# При 10000+ пользователей ставьте 0.5-0.7
QUEUE_YOUTUBE_RPS=0.7

# Лимит загрузок в Telegram в минуту (рекомендуется 30-40 для стабильности)
# Локальный API позволяет больше, но для стабильности лучше меньше
QUEUE_TELEGRAM_UPLOADS_PER_MIN=35

# Максимальное количество одновременных загрузок (рекомендуется 2-3)
# Зависит от RAM и CPU сервера
QUEUE_MAX_CONCURRENT=2

# Максимум задач в очереди на одного пользователя
QUEUE_MAX_PER_USER=100
